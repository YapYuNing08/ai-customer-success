# Copy to .env and fill in real values.
# Hosted Postgres (Neon / Supabase) — paste your connection string here.
# Neon example (note the required sslmode=require):
#   postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require
# Supabase example:
#   postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[Ning%-customer%-success]@db.hpzqttfntbzdvfucaxgy.supabase.co:5432/postgres
GEMINI_API_KEY=your-gemini-api-key-here

# Frontend origin allowed by backend CORS
FRONTEND_ORIGIN=http://localhost:5173
